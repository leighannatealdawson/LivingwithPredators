# Google Apps Script Web App deployment URL.
# Leave blank in development — the app logs submissions to the console
# and shows the thank-you screen without contacting any server.
VITE_SUBMIT_URL=

# Optional override for the Vite base path (useful if deploying to a
# custom domain). In GitHub Actions this is auto-derived from
# GITHUB_REPOSITORY, so you typically do not need to set this.
# VITE_BASE_PATH=/my-repo-name/
